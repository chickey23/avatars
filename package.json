{
  "name": "avatars",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:viewer": "vite --config vite.config.viewer.ts",
    "build": "tsc -b && vite build",
    "build:viewer": "vite build --config vite.config.viewer.ts && node scripts/finish-viewer-dist.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify.ps1",
    "discovery:probe": "tsx scripts/discovery-probe.ts",
    "discovery:wiki": "tsx scripts/discovery-live-wikipedia.ts",
    "discovery:wikidata": "tsx scripts/wikidata-resolve.ts",
    "gen:audio": "node scripts/gen-audio-cues.mjs",
    "tauri": "tauri",
    "tauri:dev:viewer": "cd viewer-tauri && tauri dev",
    "tauri:build:viewer": "cd viewer-tauri && tauri build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "~5.6.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
