{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:window:allow-set-title",
    "shell:allow-open"
  ]
}
