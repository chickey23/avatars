{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "viewer-main-capability",
  "description": "Read-only viewer window — no shell plugin",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:webview:default",
    "core:window:allow-set-title"
  ]
}
